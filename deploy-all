#!/bin/zsh
# Deploy Big Brother to all child devices (and parent).
# Usage: ./deploy-all [--kids-only] [--parent-only] [--no-build]
#
# Three phases:
#   1. Build + Install — deploys binary to all reachable devices
#   2. Launch — keeps retrying process launch until devicectl succeeds
#   3. Heartbeat — polls CloudKit until each device sends a heartbeat with the new build
#
# Runs indefinitely until all devices are heartbeat-confirmed or you hit Ctrl-C.

set -e  # Exit on error during build phase only — disabled after build succeeds.

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_DIR"

RETRY_INTERVAL=300  # 5 minutes between install retries
LAUNCH_INTERVAL=60  # 1 minute between launch/heartbeat retries

# CloudKit API token for heartbeat verification (public database, read-only).
# Set CK_API_TOKEN env var to override.
CK_API_TOKEN="${CK_API_TOKEN:-1a091d3460a9c1b488dd4259ae2f5c7bd9200ef9dd311a42c1b447da992766b7}"
CK_CONTAINER="iCloud.fr.bigbrother.app"
CK_ENV="development"

# Device list: "name|xcode_device_id|is_parent|cloudkit_device_id"
DEVICE_LIST=(
    "e phone (parent)|4B516D91-B596-52F5-8C1D-41B14B4A1540|1|"
    "Simon's iPhone|66E78D1B-93D0-5D58-8505-DCF40709942F|0|5968290E-B2CB-4016-882A-A0FA0FE6BF2E"
    "Olivia's iPhone|A3A7322E-9740-5388-9B4C-E99B7537F2E6|0|BED217B0-4B3E-41B4-B069-8657995000BC"
    "Daphne's iPhone|39B6646E-F780-572D-AC85-9CB24851A113|0|0A2405AE-83BB-437B-B0B4-9F47027B9A17"
    "Daphne's iPad|875F45A5-CA62-515B-8C70-116B06D8021F|0|21AF5BAE-C23B-451B-9DBC-B84F40CE2ED3"
    "Isla's iPhone|DB7F2BA3-46E4-59D1-9BE1-60EAB324F183|0|08A66081-1084-44E8-8126-E3B00F536832"
    "Isla's iPad|35427EB0-3804-50B7-A069-970F7307D977|0|294960A0-7FC0-44D9-AA71-8F2990A2CF77"
    "Sebastian's iPad|C17B60F1-467D-5EC5-BA70-783D19C91249|0|4744FC3A-53CD-47E7-A8B2-72460A78E591"
    "Juliet's iPad|3B6FC561-C28A-5F20-8232-E8058A24DDCE|0|B99D9B61-F760-46C3-83AA-EAA881909D85"
)




# ANSI escape codes
BOLD="\033[1m"
DIM="\033[2m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
CYAN="\033[36m"
MAGENTA="\033[35m"
RESET="\033[0m"
CLEAR_LINE="\033[2K"
MOVE_UP="\033[A"

# Parse args
KIDS_ONLY=false
PARENT_ONLY=false
NO_BUILD=false
for arg in "$@"; do
    case $arg in
        --kids-only) KIDS_ONLY=true ;;
        --parent-only) PARENT_ONLY=true ;;
        --no-build) NO_BUILD=true ;;
    esac
done

# Build target list (filtered by flags)
TARGETS=()
for entry in $DEVICE_LIST; do
    local name="${entry%%|*}"
    local rest="${entry#*|}"
    local xcode_id="${rest%%|*}"
    local rest2="${rest#*|}"
    local is_parent="${rest2%%|*}"

    if $KIDS_ONLY && [[ "$is_parent" == "1" ]]; then continue; fi
    if $PARENT_ONLY && [[ "$is_parent" == "0" ]]; then continue; fi

    TARGETS+=("$name|$xcode_id")
done

TOTAL=${#TARGETS}

# Step 1: Build
BUILD_DIR="/tmp/bb-deploy"
if ! $NO_BUILD; then
    BUILD_NUM=$(grep 'appBuildNumber' "$PROJECT_DIR/BigBrotherCore/Sources/BigBrotherCore/Constants/AppConstants.swift" | grep -o '[0-9]*')
    echo ""
    echo "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo "${BOLD}  Big Brother Deploy${RESET}  ${DIM}b${BUILD_NUM} · $(date '+%H:%M')${RESET}"
    echo "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
    echo "🔨 Building...  ${DIM}(warnings hidden)${RESET}"
    BUILD_START=$(date +%s)
    rm -rf "$BUILD_DIR" 2>/dev/null || true
    xattr -cr "$PROJECT_DIR" 2>/dev/null || true
    BUILD_LOG=$(mktemp)
    if ! xcodebuild -project BigBrother.xcodeproj \
        -scheme BigBrother \
        -destination 'generic/platform=iOS' \
        -derivedDataPath "$BUILD_DIR" \
        -quiet \
        build >"$BUILD_LOG" 2>&1; then
        echo "${RED}❌ Build failed:${RESET}"
        cat "$BUILD_LOG"
        rm -f "$BUILD_LOG"
        exit 1
    fi
    rm -f "$BUILD_LOG"
    BUILD_END=$(date +%s)
    BUILD_SECS=$((BUILD_END - BUILD_START))
    BUILD_MIN=$((BUILD_SECS / 60))
    BUILD_SEC=$((BUILD_SECS % 60))
    if [[ $BUILD_MIN -gt 0 ]]; then
        BUILD_TIME="${BUILD_MIN}m ${BUILD_SEC}s"
    else
        BUILD_TIME="${BUILD_SEC}s"
    fi
else
    BUILD_NUM=$(grep 'appBuildNumber' "$PROJECT_DIR/BigBrotherCore/Sources/BigBrotherCore/Constants/AppConstants.swift" | grep -o '[0-9]*')
    echo ""
    echo "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo "${BOLD}  Big Brother Deploy${RESET}  ${DIM}b${BUILD_NUM} · $(date '+%H:%M') · skip build${RESET}"
    echo "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
    BUILD_TIME="skipped"
fi

APP_PATH=$(find "$BUILD_DIR" -name "BigBrother.app" -path "*/Debug-iphoneos/*" | head -1)
if [[ -z "$APP_PATH" ]]; then
    echo "${RED}❌ Can't find .app bundle${RESET}"
    exit 1
fi
DEPLOY_START=$(date +%s)
echo "${GREEN}✅ Build OK${RESET}  ${DIM}(${BUILD_TIME})${RESET}"

# Disable exit-on-error for the deploy/launch/verify loop.
# Network failures, locked devices, and CloudKit hiccups are expected — not fatal.
set +e
echo ""

# Step 2: Deploy + Launch + Heartbeat Verify loop
# States:
#   pending     → not yet attempted
#   installing  → install in progress
#   installed   → binary deployed, launch not yet attempted
#   launched    → devicectl launch succeeded (app may or may not be fully running)
#   confirmed   → CloudKit heartbeat received with new build number
#   unreachable → device not reachable, will retry install
typeset -A DEVICE_STATUS
typeset -A DEVICE_IS_PARENT
typeset -A DEVICE_ID_MAP     # Xcode device UUID
typeset -A DEVICE_CK_ID_MAP  # CloudKit enrollment device ID
typeset -A DEVICE_LAST_ATTEMPT
typeset -A DEVICE_CONFIRMED_AT
typeset -A DEVICE_HB_AGE

for entry in $TARGETS; do
    local name="${entry%%|*}"
    local rest="${entry#*|}"
    local device_id="${rest%%|*}"
    local safe_name=$(echo "$name" | tr ' /()'"'" '_____')
    DEVICE_STATUS[$safe_name]="pending"
    DEVICE_ID_MAP[$safe_name]="$device_id"
    # Find CK device ID and parent flag from DEVICE_LIST
    local is_parent=0
    local ck_id=""
    for dentry in $DEVICE_LIST; do
        local dname="${dentry%%|*}"
        local drest="${dentry#*|}"
        local dxid="${drest%%|*}"
        local drest2="${drest#*|}"
        local dp="${drest2%%|*}"
        local dck="${drest2#*|}"
        if [[ "$dname" == "$name" ]]; then
            if [[ "$dp" == "1" ]]; then is_parent=1; fi
            ck_id="$dck"
            break
        fi
    done
    DEVICE_IS_PARENT[$safe_name]=$is_parent
    DEVICE_CK_ID_MAP[$safe_name]="$ck_id"
done

CURSOR_HOME="\033[H"
CLEAR_TO_END="\033[J"

save_cursor() { clear; }
restore_and_clear() { printf "${CURSOR_HOME}${CLEAR_TO_END}"; }

format_age() {
    local secs=$1
    if [[ $secs -lt 60 ]]; then echo "${secs}s ago"
    elif [[ $secs -lt 3600 ]]; then echo "$((secs / 60))m ago"
    else echo "$((secs / 3600))h $((secs % 3600 / 60))m ago"
    fi
}

print_status() {
    echo "${BOLD}  Device                   Status${RESET}"
    echo "  ${DIM}─────────────────────────────────────────────────────────${RESET}"
    for entry in $TARGETS; do
        local name="${entry%%|*}"
        local safe_name=$(echo "$name" | tr ' /()'"'" '_____')
        local st="${DEVICE_STATUS[$safe_name]}"
        local padded=$(printf "%-24s" "$name")
        local attempt_info=""
        if [[ -n "${DEVICE_LAST_ATTEMPT[$safe_name]}" ]]; then
            attempt_info=" ${DIM}(${DEVICE_LAST_ATTEMPT[$safe_name]})${RESET}"
        fi
        case $st in
            confirmed)
                local ct="${DEVICE_CONFIRMED_AT[$safe_name]}"
                echo "  ${GREEN}✅ ${padded}${RESET} ${GREEN}heartbeat confirmed b${BUILD_NUM}${RESET} ${DIM}(${ct})${RESET}" ;;
            launched)
                local hb_age="${DEVICE_HB_AGE[$safe_name]}"
                local hb_info=""
                if [[ -n "$hb_age" && "$hb_age" -gt 0 ]]; then
                    hb_info=" ${DIM}· last hb $(format_age $hb_age)${RESET}"
                fi
                echo "  ${CYAN}⟳  ${padded}${RESET} ${CYAN}launched${RESET} — awaiting heartbeat b${BUILD_NUM}${hb_info}" ;;
            installed)
                echo "  ${YELLOW}📦 ${padded}${RESET} ${YELLOW}installed${RESET} — awaiting launch${attempt_info}" ;;
            installing)
                echo "  ${CYAN}⟳  ${padded}${RESET} ${CYAN}installing...${RESET}" ;;
            unreachable)
                echo "  ${YELLOW}⏸  ${padded}${RESET} ${DIM}not reachable${RESET}${attempt_info}" ;;
            *)
                echo "  ${DIM}·  ${padded} waiting${RESET}" ;;
        esac
    done
}

# Query CloudKit for all heartbeats and match each to a device by CloudKit device ID.
check_heartbeats() {
    local ck_url="https://api.apple-cloudkit.com/database/1/${CK_CONTAINER}/${CK_ENV}/public/records/query?ckAPIToken=${CK_API_TOKEN}"
    local response
    response=$(curl -s --max-time 15 -X POST "$ck_url" \
        -H "Content-Type: application/json" \
        -d '{
            "query": {
                "recordType": "BBHeartbeat",
                "filterBy": [{
                    "fieldName": "timestamp",
                    "comparator": "GREATER_THAN",
                    "fieldValue": {"value": 0, "type": "TIMESTAMP"}
                }]
            },
            "resultsLimit": 50
        }' 2>/dev/null) || return

    if echo "$response" | grep -q '"serverErrorCode"'; then
        return
    fi

    local deploy_ms=$((DEPLOY_START * 1000))
    local now_ms=$(($(date +%s) * 1000))

    # Parse heartbeats into "ck_device_id build timestamp_ms" lines
    local hb_data
    hb_data=$(echo "$response" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for rec in data.get('records', []):
    f = rec.get('fields', {})
    did = f.get('deviceID', {}).get('value', '')
    build = f.get('hbAppBuildNumber', {}).get('value', 0)
    ts = f.get('timestamp', {}).get('value', 0)
    if did and not did.startswith('SchemaSeed'):
        print(f'{did} {build} {ts}')
" 2>/dev/null) || return

    # Match each heartbeat to a device
    for entry in $TARGETS; do
        local name="${entry%%|*}"
        local safe_name=$(echo "$name" | tr ' /()'"'" '_____')
        local ck_id="${DEVICE_CK_ID_MAP[$safe_name]}"
        [[ -z "$ck_id" ]] && continue  # parent device, no CK ID

        # Find this device's heartbeat
        local hb_line=$(echo "$hb_data" | grep "^${ck_id} " 2>/dev/null)
        [[ -z "$hb_line" ]] && continue

        local hb_build=$(echo "$hb_line" | awk '{print $2}')
        local hb_ts=$(echo "$hb_line" | awk '{print $3}')
        local age_secs=$(( (now_ms - hb_ts) / 1000 ))
        DEVICE_HB_AGE[$safe_name]=$age_secs

        # Confirm if heartbeat has new build and was sent after deploy started
        if [[ "$hb_build" == "$BUILD_NUM" && $hb_ts -gt $deploy_ms ]]; then
            if [[ "${DEVICE_STATUS[$safe_name]}" != "confirmed" ]]; then
                DEVICE_STATUS[$safe_name]="confirmed"
                DEVICE_CONFIRMED_AT[$safe_name]=$(date '+%H:%M')
            fi
        fi
    done

    # Parent device: confirm once launched (no heartbeat to check)
    for entry in $TARGETS; do
        local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
        if [[ "${DEVICE_IS_PARENT[$safe_name]}" == "1" && "${DEVICE_STATUS[$safe_name]}" == "launched" ]]; then
            DEVICE_STATUS[$safe_name]="confirmed"
            DEVICE_CONFIRMED_AT[$safe_name]=$(date '+%H:%M')
        fi
    done
}

save_cursor
print_status
echo ""
echo "  ${DIM}Starting...${RESET}"

trap "echo ''; echo '  ${DIM}Stopped.${RESET}'; echo ''; exit 0" INT

LAST_DEPLOY_TIME=0
TICK=0

while true; do
    TICK=$((TICK + 1))
    NOW=$(date +%s)
    RESULT_DIR=$(mktemp -d)

    # Check if all done
    local all_done=true
    for entry in $TARGETS; do
        local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
        if [[ "${DEVICE_STATUS[$safe_name]}" != "confirmed" ]]; then
            all_done=false
            break
        fi
    done
    if $all_done; then
        restore_and_clear
        print_status
        echo ""
        echo "  ${GREEN}${BOLD}${TOTAL}/${TOTAL} all heartbeat-confirmed!${RESET}  🎉"
        echo ""
        break
    fi

    # Phase 1: Install — try unreachable/pending devices every 5 minutes
    if [[ $((NOW - LAST_DEPLOY_TIME)) -ge $RETRY_INTERVAL || $TICK -eq 1 ]]; then
        LAST_DEPLOY_TIME=$NOW
        PIDS=()
        for entry in $TARGETS; do
            local name="${entry%%|*}"
            local safe_name=$(echo "$name" | tr ' /()'"'" '_____')
            local st="${DEVICE_STATUS[$safe_name]}"
            if [[ "$st" == "confirmed" || "$st" == "installed" || "$st" == "launched" ]]; then continue; fi
            DEVICE_STATUS[$safe_name]="installing"
            local did="${DEVICE_ID_MAP[$safe_name]}"
            (
                if xcrun devicectl device install app --device "$did" "$APP_PATH" >/dev/null 2>&1; then
                    touch "$RESULT_DIR/${safe_name}_installed"
                fi
            ) &
            PIDS+=($!)
        done
        for pid in $PIDS; do wait $pid 2>/dev/null; done

        ATTEMPT_TIME=$(date '+%H:%M')
        for entry in $TARGETS; do
            local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
            if [[ -f "$RESULT_DIR/${safe_name}_installed" ]]; then
                DEVICE_STATUS[$safe_name]="installed"
                DEVICE_LAST_ATTEMPT[$safe_name]="$ATTEMPT_TIME"
            elif [[ "${DEVICE_STATUS[$safe_name]}" == "installing" ]]; then
                DEVICE_STATUS[$safe_name]="unreachable"
                DEVICE_LAST_ATTEMPT[$safe_name]="$ATTEMPT_TIME"
            fi
        done
    fi

    # Phase 2: Launch — try installed devices
    PIDS=()
    for entry in $TARGETS; do
        local name="${entry%%|*}"
        local safe_name=$(echo "$name" | tr ' /()'"'" '_____')
        local st="${DEVICE_STATUS[$safe_name]}"
        if [[ "$st" != "installed" ]]; then continue; fi

        local did="${DEVICE_ID_MAP[$safe_name]}"
        (
            if xcrun devicectl device process launch --device "$did" fr.bigbrother.app >/dev/null 2>&1; then
                touch "$RESULT_DIR/${safe_name}_launched"
            fi
        ) &
        PIDS+=($!)
    done
    for pid in $PIDS; do wait $pid 2>/dev/null; done

    ATTEMPT_TIME=$(date '+%H:%M')
    for entry in $TARGETS; do
        local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
        if [[ -f "$RESULT_DIR/${safe_name}_launched" ]]; then
            DEVICE_STATUS[$safe_name]="launched"
            DEVICE_LAST_ATTEMPT[$safe_name]="$ATTEMPT_TIME"
        fi
    done

    # Also retry launch for "launched" devices (in case previous launch was on locked screen
    # and the kid has since unlocked)
    PIDS=()
    for entry in $TARGETS; do
        local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
        if [[ "${DEVICE_STATUS[$safe_name]}" == "launched" ]]; then
            local did="${DEVICE_ID_MAP[$safe_name]}"
            (xcrun devicectl device process launch --device "$did" fr.bigbrother.app >/dev/null 2>&1) &
            PIDS+=($!)
        fi
    done
    for pid in $PIDS; do wait $pid 2>/dev/null; done

    rm -rf "$RESULT_DIR"

    # Phase 3: Check CloudKit heartbeats
    check_heartbeats

    # Recount
    local n_confirmed=0 n_launched=0 n_installed=0 n_unreachable=0
    for entry in $TARGETS; do
        local safe_name=$(echo "${entry%%|*}" | tr ' /()'"'" '_____')
        case "${DEVICE_STATUS[$safe_name]}" in
            confirmed) n_confirmed=$((n_confirmed + 1)) ;;
            launched) n_launched=$((n_launched + 1)) ;;
            installed) n_installed=$((n_installed + 1)) ;;
            unreachable|pending) n_unreachable=$((n_unreachable + 1)) ;;
        esac
    done

    # Redraw
    restore_and_clear
    print_status

    echo ""
    local parts="${GREEN}${BOLD}${n_confirmed}/${TOTAL}${RESET} ${GREEN}heartbeat-confirmed${RESET}"
    if [[ $n_launched -gt 0 ]]; then parts="${parts} · ${CYAN}${n_launched} awaiting heartbeat${RESET}"; fi
    if [[ $n_installed -gt 0 ]]; then parts="${parts} · ${YELLOW}${n_installed} awaiting launch${RESET}"; fi
    if [[ $n_unreachable -gt 0 ]]; then parts="${parts} · ${DIM}${n_unreachable} unreachable${RESET}"; fi
    echo "  ${parts} ${DIM}(Ctrl-C to stop)${RESET}"

    if [[ $n_confirmed -ge $TOTAL ]]; then
        echo ""
        echo "  ${GREEN}${BOLD}All devices heartbeat-confirmed!${RESET}  🎉"
        echo ""
        break
    fi

    # Wait between attempts, showing simple countdown on the same line
    for ((s=LAUNCH_INTERVAL; s>0; s--)); do
        printf "\r${CLEAR_LINE}  ${DIM}retry in ${s}s${RESET}"
        sleep 1
    done
done
